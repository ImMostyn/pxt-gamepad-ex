{
    "name": "gamepad-ex",
    "version": "1.0.0",
    "description": "This extension adds gamepad support to the micro:bit. It allows you to connect a gamepad to the micro:bit and use it to control your projects.",
    "author": "immostyn",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/immostyn/pxt-gamepad-ex"
    },
    "dependencies": {
        "core": "*",
        "radio": "*"
    },
    "files": [
        "main.blocks",
        "main.ts",
        "README.md",
        "gamepad.ts"
    ],
    "testFiles": [
        "test.ts"
    ],
    "targetVersions": {
        "target": "8.0.18",
        "targetId": "microbit"
    },
    "supportedTargets": [
        "microbit"
    ],
    "preferredEditor": "tsprj"
}
